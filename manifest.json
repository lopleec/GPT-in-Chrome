{
  "manifest_version": 3,
  "name": "GPT in Chrome",
  "version": "0.1.0",
  "description": "A Chrome side-panel copilot with screenshots, page reading, console access, and webpage actions through OpenAI-compatible APIs.",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "activeTab",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "GPT in Chrome",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
